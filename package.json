{
  "name": "neural-forge",
  "version": "1.0.0",
  "description": "Visual AI Agent Builder with Self-Improving Local Agents",
  "main": "dist/index.js",
  "bin": {
    "neural-forge": "dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js start",
    "dev": "tsx watch src/cli.ts start",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "ai",
    "agents",
    "automation",
    "llm",
    "local-ai",
    "self-improving",
    "visual-builder",
    "workflow",
    "autonomous"
  ],
  "author": "Gracestack AB <hello@gracestack.se>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gracestack/NeuralForge.git"
  },
  "bugs": {
    "url": "https://github.com/gracestack/NeuralForge/issues"
  },
  "homepage": "https://neuralforge.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "ws": "^8.14.2",
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^21.5.0",
    "playwright": "^1.40.0",
    "openai": "^4.20.0",
    "langchain": "^0.0.210",
    "faiss-node": "^0.5.1",
    "chromadb": "^1.7.3",
    "vectordb": "^0.4.9",
    "node-cron": "^3.0.3",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "yaml": "^2.3.4",
    "toml": "^3.0.0",
    "semver": "^7.5.4",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.10",
    "chokidar": "^3.5.3",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "rate-limiter-flexible": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.20",
    "@types/ws": "^8.5.8",
    "@types/uuid": "^9.0.6",
    "@types/lodash": "^4.14.200",
    "@types/inquirer": "^9.0.6",
    "@types/jest": "^29.5.7",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.1.4",
    "typescript": "^5.2.2",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  }
}
